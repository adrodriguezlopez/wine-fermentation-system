[flake8]
max-line-length = 120
# PRE-EXISTING DEBT — tracked in GitHub issue #3.
# The codes below are globally suppressed because the existing codebase has many
# violations that must be fixed incrementally. Do NOT use this as an excuse to
# write new violations — all new code must be clean.
#
# Codes kept active (real bugs, not style):
#   E9xx  — syntax errors
#   W6xx  — deprecated Python features
#
# Codes suppressed (pre-existing style/quality debt):
#   E203  — whitespace before ':'
#   E402  — module-level import not at top
#   E501  — line too long (codebase predates 120-char limit)
#   E712  — comparison to True/False
#   E722  — bare except
#   F401  — imported but unused
#   F402  — import shadowed by loop variable
#   F403  — star import used
#   F541  — f-string without placeholders
#   F841  — local variable assigned but never used
#   W293  — blank line contains whitespace
extend-ignore =
    E203,
    E402,
    E501,
    E712,
    E722,
    F401,
    F402,
    F403,
    F541,
    F841,
    W293

per-file-ignores =
    # Tests also allow redefinitions and == comparisons
    tests/*:F811
    # Pre-existing undefined names in source — tracked in issue #3
    src/api/routers/protocol_router.py:F821
    src/api/schemas/responses/sample_responses.py:F821
