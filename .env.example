# =============================================================================
# Wine Fermentation System — Environment Variables Template
# =============================================================================
# Copy this file to .env.<environment> and fill in real values.
# NEVER commit .env.dev / .env.staging / .env.prod — only this file.
#
# Usage:
#   cp .env.example .env.dev       → local development
#   cp .env.example .env.test      → CI / integration tests
#   cp .env.example .env.staging   → staging server
#   cp .env.example .env.prod      → production server
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Sync URL used by Alembic migrations (psycopg2 driver)
DATABASE_URL=postgresql://postgres:changeme@db:5432/wine_fermentation

# Async URL used by FastAPI services at runtime (asyncpg driver)
DATABASE_ASYNC_URL=postgresql+asyncpg://postgres:changeme@db:5432/wine_fermentation

# PostgreSQL container credentials (used by the db service itself)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=wine_fermentation

# Host port that PostgreSQL is exposed on (change per env to avoid clashes)
POSTGRES_HOST_PORT=5432

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Minimum 32 characters. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_a_secure_random_secret_of_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# CORS (comma-separated list of allowed origins)
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Alert Scheduler (fermentation service)
# -----------------------------------------------------------------------------
# How often (minutes) the background job scans for overdue/due-soon steps
ALERT_SCHEDULER_INTERVAL_MINUTES=30

# -----------------------------------------------------------------------------
# Service ports (host-side, container always listens on internal port)
# -----------------------------------------------------------------------------
FERMENTATION_HOST_PORT=8000
WINERY_HOST_PORT=8001
FRUIT_ORIGIN_HOST_PORT=8002
ANALYSIS_ENGINE_HOST_PORT=8003
