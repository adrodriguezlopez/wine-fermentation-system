[flake8]
max-line-length = 120
# E402: module-level import not at top — common in test setup files
extend-ignore = E402
per-file-ignores =
    # Tests: allow unused imports (fixtures), f-strings without placeholders,
    # redefinitions, unused vars, == True/False comparisons, long lines
    tests/*:F401,F541,F811,F841,E712,E501
    # Root-level scripts (DB helpers, generators): ignore unused imports
    *.py:F401
    # SOURCE FILES — pre-existing debt, tracked in GitHub issue #3.
    # Do NOT add new entries here. Fix the violations instead.
    src/api/error_handlers.py:F401
    src/api/routers/action_router.py:F401
    src/api/routers/alert_router.py:F401
    src/api/routers/fermentation_router.py:F401,E501
    src/api/routers/historical_router.py:F401
    src/api/routers/protocol_execution_router.py:F401
    src/api/routers/protocol_router.py:F401,F821,E501
    src/api/routers/protocol_step_router.py:F401
    src/api/routers/sample_router.py:F401
    src/api/routers/step_completion_router.py:F841
    src/api/schemas/requests/protocol_requests.py:E501
    src/api/schemas/responses/historical_responses.py:F401
    src/api/schemas/responses/protocol_responses.py:E501
    src/api/schemas/responses/sample_responses.py:F821
    src/domain/__init__.py:F401
    src/domain/entities/protocol_alert.py:F401,E501
    src/domain/entities/protocol_execution.py:F401,E501
    src/domain/entities/step_completion.py:F401
    src/domain/entities/winemaker_action.py:F401
    src/domain/repositories/fermentation_repository_interface.py:F401
    src/domain/repositories/protocol_alert_repository_interface.py:F401
    src/domain/repositories/protocol_execution_repository_interface.py:F401
    src/domain/repositories/sample_repository_interface.py:F401,E501
    src/repository_component/__init__.py:F401
    src/repository_component/protocol_alert_repository.py:F401
    src/repository_component/repositories/fermentation_note_repository.py:F401
    src/repository_component/repositories/sample_repository.py:F401
    src/service_component/etl/etl_service.py:F401
    src/service_component/etl/etl_validator.py:F401
    src/service_component/interfaces/business_rule_validation_service_interface.py:F401
    src/service_component/interfaces/validation_service_interface.py:F401
    src/service_component/services/alert_scheduler_service.py:F401
    src/service_component/services/fermentation_note_service.py:F401
    src/service_component/services/fermentation_service.py:F401,E501
    src/service_component/services/historical/historical_data_service.py:F841
    src/service_component/services/protocol_alert_service.py:F401,E501
    src/service_component/services/protocol_compliance_service.py:F401
    src/service_component/services/protocol_service.py:F401,F841
    src/service_component/services/validation_orchestrator.py:E501
    src/service_component/services/validation_service.py:F401
    src/service_component/validators/fermentation_validator.py:E501
